{
  "openapi": "3.0.0",
  "info": {
    "title": "AIML API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.aimlapi.com"
    }
  ],
  "paths": {
    "/v1/stt/create": {
      "post": {
        "operationId": "_v1_stt_create",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "enum": [
                      "openai/gpt-4o-transcribe"
                    ]
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the input audio file."
                  },
                  "file": {
                    "type": "object",
                    "properties": {
                      "buffer": {
                        "anyOf": [
                          {
                            "nullable": true
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "Buffer"
                                ]
                              },
                              "data": {
                                "type": "array",
                                "items": {
                                  "type": "number"
                                }
                              }
                            },
                            "required": [
                              "type",
                              "data"
                            ]
                          },
                          {
                            "nullable": true
                          }
                        ]
                      },
                      "mimetype": {
                        "type": "string"
                      },
                      "size": {
                        "type": "integer"
                      },
                      "originalname": {
                        "type": "string"
                      },
                      "encoding": {
                        "type": "string"
                      },
                      "fieldname": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "mimetype",
                      "originalname",
                      "encoding",
                      "fieldname"
                    ],
                    "description": "The audio file to transcribe.",
                    "format": "binary"
                  },
                  "language": {
                    "type": "string",
                    "description": "The BCP-47 language tag that hints at the primary spoken language. Depending on the Model and API endpoint you choose only certain languages are available"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "An optional text to guide the model's style or continue a previous audio segment. The prompt should match the audio language."
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "default": 0,
                    "description": "The sampling temperature, between 0 and 1. Higher values like 0.8 will make the output more random, while lower values like 0.2 will make it more focused and deterministic."
                  }
                },
                "required": [
                  "model"
                ],
                "title": "openai/gpt-4o-transcribe"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "generation_id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "generation_id"
                  ]
                }
              }
            }
          }
        },
        "x-hideTryItPanel": true,
        "x-codeSamples": [
          {
            "lang": "cURL",
            "source": "curl -L \\\n  --request POST \\\n  --url 'https://api.aimlapi.com/v1/stt/create' \\\n  --header 'Authorization: Bearer <YOUR_AIMLAPI_KEY>' \\\n  --header 'Content-Type: application/json' \\\n  --data '{\n      \"model\": \"openai/gpt-4o-transcribe\",\n      \"url\": \"https://audio-samples.github.io/samples/mp3/blizzard_primed/sample-0.mp3\"\n    }'"
          },
          {
            "lang": "JavaScript",
            "source": "async function main() {\n  const response = await fetch('https://api.aimlapi.com/v1/stt/create', {\n    method: 'POST',\n    headers: {\n      'Authorization': 'Bearer <YOUR_AIMLAPI_KEY>',\n      'Content-Type': 'application/json',\n    },\n    body: JSON.stringify({\n      \"model\": \"openai/gpt-4o-transcribe\",\n      \"url\": \"https://audio-samples.github.io/samples/mp3/blizzard_primed/sample-0.mp3\"\n    }),\n  });\n\n  const data = await response.json();\n  console.log(JSON.stringify(data, null, 2));\n}\n\nmain();"
          },
          {
            "lang": "Python",
            "source": "import requests\n\nresponse = requests.post(\n    \"https://api.aimlapi.com/v1/stt/create\",\n    headers={\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": \"Bearer <YOUR_AIMLAPI_KEY>\",\n    },\n    json={\n      \"model\": \"openai/gpt-4o-transcribe\",\n      \"url\": \"https://audio-samples.github.io/samples/mp3/blizzard_primed/sample-0.mp3\"\n    }\n)\n\ndata = response.json()\nprint(data)"
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "<YOUR_AIMLAPI_KEY>",
        "type": "http",
        "description": "Bearer key"
      }
    }
  }
}